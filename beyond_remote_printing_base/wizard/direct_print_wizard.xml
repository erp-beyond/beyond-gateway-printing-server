<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="direct_print_wizard_form_view" model="ir.ui.view">
        <field name="name">direct_print_wizard_form_view</field>
        <field name="model">print.direct.wizard</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <h4 class="my-2">Enter the amount of prints and select a printer.</h4>
                </header>

                <div class="oe_title mb-2">
                    <h3 class="d-flex">
                        <field name="name"/>
                    </h3>
                </div>

                <group>
                    <group name="group_1">
                        <field name="allowed_printer_ids" invisible="1" />
                        <!-- <field name="res_partner_id" /> -->
                        <field name="printer_id" domain="[('id','in', allowed_printer_ids)]" invisible="allowed_printer_ids == False" />
                        <field name="printer_id" invisible="allowed_printer_ids != False"/>
                    </group>
                </group>

                <group>
                    <field name="print_lines" nolabel="1" colspan="2">
                        <list create="false" editable="top">
                            <field name="allowed_printer_ids" column_invisible="1" />
                            <field name="print_job_type" column_invisible="1" />
                            <field name="name" readonly="1" />
                            <!-- <field name="partner_id" /> -->
                            <field name="print_qty" />
                            <field name="printer_id" domain="[('id','in', allowed_printer_ids)]" />
                            <button name="action_preview_label" string="Preview Label" type="object" class="oe_highlight" groups="beyond_remote_printing_base.group_remote_printing_manager"/>
                            <field name="zpl_value" widget="CopyClipboardChar" groups="beyond_remote_printing_base.group_remote_printing_manager"/>
                        </list>
                    </field>
                </group>

                <footer>
                    <button name="action_print" type="object" data-hotkey="q" string="Print" class="oe_highlight" icon="fa-print" />
                </footer>
            </form>
        </field>
    </record>

</odoo>