<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Servers -->
    <record id="remote_printer_servers_view_list" model="ir.ui.view">
        <field name="name">remote.printer.server.list</field>
        <field name="model">remote.printer.server</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />
                <field name="technical_name" />
                <field name="online" />
                <field name="last_connection" />
                <field name="printer_ids" widget="many2many_tags" />
            </list>
        </field>
    </record>

    <record id="view_remote_printer_server_form" model="ir.ui.view">
        <field name="name">remote.printer.server.form</field>
        <field name="model">remote.printer.server</field>
        <field name="arch" type="xml">
            <form string="Remote Printer Server">
                <sheet>
                    <header>
                        <button name="set_cancel_tasks" string="Cancel All Tasks" type="object" class="btn-warning"></button>
                    </header>
                    <group>
                        <field name="name" />
                        <field name="technical_name" />
                        <field name="online" readonly="1" />
                        <field name="last_connection" readonly="1" />
                    </group>
                    <notebook>
                        <page string="Printers">
                            <field name="printer_ids">
                                <list>
                                    <field name="sequence" widget="handle" />
                                    <field name="name" />
                                    <field name="technical_name" />
                                    <field name="default_label_type_id" widget="many2many_tags" />
                                    <field name="zpl" />
                                    <field name="state" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="remote_printer_servers_action" model="ir.actions.act_window">
        <field name="name">Print Server</field>
        <field name="res_model">remote.printer.server</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>