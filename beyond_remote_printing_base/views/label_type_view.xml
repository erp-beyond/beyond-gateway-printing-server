<odoo>
    <data>


        <!-- Tree/List View for Label Titles -->
        <record id="view_label_title_list" model="ir.ui.view">
            <field name="name">label.title.list</field>
            <field name="model">label.title</field>
            <field name="arch" type="xml">
                <list string="Label Titles" editable="top">
                    <field name="key" />
                    <field name="value" />
                </list>
            </field>
        </record>

        <!-- Form View for Label Titles -->
        <record id="view_label_title_form" model="ir.ui.view">
            <field name="name">label.title.form</field>
            <field name="model">label.title</field>
            <field name="arch" type="xml">
                <form string="Label Title">
                    <sheet>
                        <group>
                            <field name="key" />
                            <field name="value" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action to Open List View of Label Titles -->
        <record id="action_label_title" model="ir.actions.act_window">
            <field name="name">Label Titles</field>
            <field name="res_model">label.title</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create and manage label titles.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_label_title" name="Label Titles" parent="remote_printer_menu_root" action="action_label_title" sequence="10" />
    </data>
</odoo>