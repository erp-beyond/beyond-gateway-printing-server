<odoo>
    <data>


        <!-- Tree/List View for label.types -->
        <record id="view_label_type_list" model="ir.ui.view">
            <field name="name">label.type.list</field>
            <field name="model">label.type</field>
            <field name="arch" type="xml">
                <list string="label.types" editable="top">
                    <field name="key" />
                    <field name="name" />
                    <field name="label_home_x_rotate" />
                    <field name="label_home_y_rotate" />
                </list>
            </field>
        </record>

        <!-- Form View for label.types -->
        <record id="view_label_type_form" model="ir.ui.view">
            <field name="name">label.type.form</field>
            <field name="model">label.type</field>
            <field name="arch" type="xml">
                <form string="label.type">
                    <sheet>
                        <group>
                            <field name="key" />
                            <field name="name" />
                            <field name="label_home_x_rotate" />
                            <field name="label_home_y_rotate" />
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Action to Open List View of label.types -->
        <record id="action_label_type" model="ir.actions.act_window">
            <field name="name">Label Types</field>
            <field name="res_model">label.type</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create and manage label types
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_label_type" name="Label Types" parent="remote_printer_menu_root" action="action_label_type" sequence="10" />
    </data>
</odoo>