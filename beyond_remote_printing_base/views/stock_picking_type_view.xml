<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="inherit_view_id_inherit_module_name" model="ir.ui.view">
        <field name="name">model.name.view.form.inherit</field>
        <field name="model">stock.picking.type</field>
        <field name="inherit_id" ref="stock.view_picking_type_form"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page name="remote_printing" string="Printing">
                    <group>
                        <field name="printer_id" widget="many2many_tags" />
                    </group>
                    <group name="direct_print" string="Direct Print on Validation">
                        <group string="Delivery Slip" name="delivery_slip">
                            <field name="auto_print_delivery_slip_direct_print" string="Delivery Slip"/>
                            <field name="delivery_slip_qty" string="Qty" invisible="auto_print_delivery_slip_direct_print == False" widget="integer"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

</odoo>
